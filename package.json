{
  "name": "export_to_markdown",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "esbuild src/content.js src/popup.js src/options.js --bundle --outdir=dist --format=esm --platform=browser",
    "watch": "esbuild src/content.js src/popup.js src/options.js --bundle --outdir=dist --format=esm --platform=browser --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "package": "yarn build && zip -r export-to-markdown.xpi manifest.json popup.html options.html dist/ icons/ _locales/ --exclude '*.DS_Store'",
    "ext:build": "yarn build && web-ext build",
    "ext:lint": "web-ext lint",
    "ext:run": "yarn build && web-ext run",
    "ext:sign": "yarn build && web-ext sign --channel=listed --amo-metadata=amo-metadata.json --api-key=$WEB_EXT_API_KEY --api-secret=$WEB_EXT_API_SECRET"
  },
  "dependencies": {
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-jsonc": "^3.1.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "vitest": "^4.1.4",
    "web-ext": "^10.1.0"
  }
}
